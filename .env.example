# =============================================================================
# SentinelCore SOAR — Variáveis de Ambiente
# Copie este arquivo para .env e preencha com seus valores reais.
# NUNCA versione o arquivo .env com chaves reais.
# =============================================================================


# =============================================================================
# THREAT INTELLIGENCE
# =============================================================================

# [OBRIGATÓRIO para enriquecimento] Chave da API do VirusTotal
# Obter em: https://www.virustotal.com → Account → API Key
VT_API_KEY=your_virustotal_api_key_here

# [OBRIGATÓRIO para enriquecimento] Chave da API do AbuseIPDB
# Obter em: https://www.abuseipdb.com → Account → API
ABUSEIPDB_API_KEY=your_abuseipdb_api_key_here

# [Opcional] Janela de tempo (em dias) para consultas de abuso no AbuseIPDB (padrão: 90)
ABUSE_MAX_AGE=90

# [Opcional] Chave da API do GreyNoise Community (enriquecimento de IPs)
# Obter em: https://www.greynoise.io → Account → API Access
# Só consultado para IOCs do tipo "ip"
GREYNOISE_API_KEY=your_greynoise_api_key_here

# [Opcional] Chave da API do Shodan (portas abertas e CVEs de IPs)
# Obter em: https://account.shodan.io
# Só consultado para IOCs do tipo "ip"
SHODAN_API_KEY=your_shodan_api_key_here

# [Opcional] Chave da API do OTX AlienVault (pulses de threat intel)
# Obter em: https://otx.alienvault.com → API Integration
# Consultado para todos os tipos de IOC (ip, domain, url, hash)
OTX_API_KEY=your_otx_api_key_here


# =============================================================================
# API SECURITY
# =============================================================================

# [Opcional] Habilitar autenticação obrigatória na API (padrão: false)
# Se true, todas as rotas (exceto /health) exigem API Key ou JWT
MINI_SOAR_REQUIRE_AUTH=false

# [Opcional] Lista de API Keys válidas separadas por vírgula
# Enviar no header: X-API-Key: <chave>
MINI_SOAR_API_KEYS=chave-secreta-1,chave-secreta-2

# [Opcional] Segredo para assinar tokens JWT (algoritmo HS256)
# Enviar no header: Authorization: Bearer <token>
MINI_SOAR_JWT_SECRET=seu-segredo-jwt-aqui

# [Opcional] Limite de requisições por cliente por janela de tempo (padrão: 60)
MINI_SOAR_API_RATE_LIMIT=60

# [Opcional] Janela de tempo do rate limit em segundos (padrão: 60)
MINI_SOAR_API_RATE_WINDOW_SECONDS=60


# =============================================================================
# TICKETING
# =============================================================================

# [Opcional] Backend para abertura de tickets: none | file | webhook | jira (padrão: file)
MINI_SOAR_TICKET_BACKEND=file

# [Opcional] Score mínimo para abrir ticket automaticamente (padrão: 70)
MINI_SOAR_TICKET_THRESHOLD=70

# [Opcional] Arquivo de saída para tickets no modo "file" (padrão: tickets.jsonl)
MINI_SOAR_TICKET_FILE=tickets.jsonl

# --- Webhook ---
# [Opcional] URL do webhook para envio de tickets (modo webhook)
TICKET_WEBHOOK_URL=https://hooks.exemplo.com/soar

# [Opcional] Token de autenticação do webhook
TICKET_WEBHOOK_TOKEN=seu-token-webhook-aqui

# --- Jira ---
# [Opcional] URL base da instância Jira (modo jira)
JIRA_BASE_URL=https://suaempresa.atlassian.net

# [Opcional] E-mail da conta Jira
JIRA_EMAIL=usuario@suaempresa.com

# [Opcional] Token de API do Jira
# Obter em: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=seu-token-jira-aqui

# [Opcional] Chave do projeto Jira onde os tickets serão abertos
JIRA_PROJECT_KEY=SOC

# [Opcional] Tipo de issue Jira a criar (padrão: Task)
JIRA_ISSUE_TYPE=Task


# =============================================================================
# INTEGRATIONS
# =============================================================================

# [Opcional] Integrações ativas separadas por vírgula: thehive, splunk, sentinel
MINI_SOAR_INTEGRATION_TARGETS=

# [Opcional] Score mínimo para disparar integrações (padrão: 60)
MINI_SOAR_INTEGRATION_THRESHOLD=60

# --- TheHive ---
# [Opcional] URL da instância TheHive
THEHIVE_URL=http://thehive.exemplo.com:9000

# [Opcional] API Key do TheHive
THEHIVE_API_KEY=seu-token-thehive-aqui

# [Opcional] Tipo de alerta no TheHive (padrão: external)
THEHIVE_ALERT_TYPE=external

# [Opcional] TLP do alerta TheHive: 0=WHITE 1=GREEN 2=AMBER 3=RED (padrão: 2)
THEHIVE_TLP=2

# [Opcional] PAP do alerta TheHive: 0=WHITE 1=GREEN 2=AMBER 3=RED (padrão: 2)
THEHIVE_PAP=2

# --- Splunk HEC ---
# [Opcional] URL do Splunk HTTP Event Collector
SPLUNK_HEC_URL=https://splunk.exemplo.com:8088/services/collector/event

# [Opcional] Token do Splunk HEC
SPLUNK_HEC_TOKEN=seu-token-splunk-aqui

# [Opcional] Sourcetype dos eventos enviados ao Splunk (padrão: mini_soar:ioc)
SPLUNK_SOURCETYPE=mini_soar:ioc

# --- Microsoft Sentinel ---
# [Opcional] ID do workspace do Microsoft Sentinel
SENTINEL_WORKSPACE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# [Opcional] Chave compartilhada do workspace Sentinel
SENTINEL_SHARED_KEY=sua-chave-sentinel-aqui

# [Opcional] Nome do log customizado no Sentinel (padrão: MiniSoarIOC)
SENTINEL_LOG_TYPE=MiniSoarIOC

# [Opcional] Endpoint customizado do Sentinel (deixe vazio para usar o padrão)
SENTINEL_ENDPOINT=


# =============================================================================
# QUEUE / WORKER (Redis + RQ)
# =============================================================================

# [Opcional] URL de conexão com o Redis (padrão: redis://localhost:6379/0)
MINI_SOAR_REDIS_URL=redis://127.0.0.1:6379/0


# =============================================================================
# DATABASE
# =============================================================================

# [Opcional] URL do banco de dados para persistência de findings
# SQLite (local, sem configuração extra):
MINI_SOAR_DATABASE_URL=sqlite:///mini_soar.db
# PostgreSQL (produção):
# MINI_SOAR_DATABASE_URL=postgresql://usuario:senha@localhost:5432/mini_soar

# [Opcional] Habilitar persistência de findings no banco (padrão: true)
MINI_SOAR_PERSIST_FINDINGS=true


# =============================================================================
# RELIABILITY
# =============================================================================

# [Opcional] Timeout padrão para chamadas externas em segundos (padrão: 20)
MINI_SOAR_TIMEOUT=20

# [Opcional] Timeout específico para chamadas ao VirusTotal (padrão: 20)
MINI_SOAR_VT_TIMEOUT=20

# [Opcional] Timeout específico para chamadas ao AbuseIPDB (padrão: 20)
MINI_SOAR_ABUSE_TIMEOUT=20

# [Opcional] Timeout específico para chamadas ao GreyNoise (padrão: 20)
MINI_SOAR_GREYNOISE_TIMEOUT=20

# [Opcional] Timeout específico para chamadas ao Shodan (padrão: 20)
MINI_SOAR_SHODAN_TIMEOUT=20

# [Opcional] Timeout específico para chamadas ao OTX AlienVault (padrão: 20)
MINI_SOAR_OTX_TIMEOUT=20

# [Opcional] Timeout específico para chamadas de integrações (padrão: 20)
MINI_SOAR_INTEGRATION_TIMEOUT=20

# [Opcional] Número máximo de tentativas em caso de falha (padrão: 2)
MINI_SOAR_MAX_RETRIES=2

# [Opcional] Tempo base de espera entre tentativas em segundos (padrão: 0.5)
MINI_SOAR_RETRY_BACKOFF_SECONDS=0.5

# [Opcional] Sleep entre processamento de IOCs em segundos (padrão: 0)
MINI_SOAR_SLEEP=0

# [Opcional] Habilitar idempotência — evita reprocessar o mesmo IOC (padrão: true)
MINI_SOAR_ENABLE_IDEMPOTENCY=true

# [Opcional] Janela de idempotência em segundos (padrão: 3600 = 1 hora)
MINI_SOAR_IDEMPOTENCY_WINDOW_SECONDS=3600


# =============================================================================
# OBSERVABILITY
# =============================================================================

# [Opcional] Nível de log: DEBUG | INFO | WARNING | ERROR (padrão: INFO)
MINI_SOAR_LOG_LEVEL=INFO

# [Opcional] Logs em formato JSON estruturado (padrão: true)
# false = logs legíveis no terminal; true = logs para ingestão em SIEM
MINI_SOAR_JSON_LOGS=true

# [Opcional] Ativar modo demo: enriquecimento simulado, sem chamadas externas (padrão: false)
# Útil para testes, demonstrações e avaliação do projeto sem API keys reais
MINI_SOAR_DEMO_MODE=false


# =============================================================================
# PLUGINS
# =============================================================================

# [Opcional] Módulos Python de plugins customizados separados por vírgula
# Exemplo: meu_plugin,outro_plugin
MINI_SOAR_PLUGIN_MODULES=


# =============================================================================
# FEED INGESTION (CSV / STIX)
# =============================================================================

# [Opcional] Habilitar ingestão periódica automática de feeds (padrão: false)
MINI_SOAR_FEED_ENABLED=false

# [Opcional] URLs de feeds IOC separadas por vírgula (CSV ou STIX 2.1)
# Exemplo: https://feeds.exemplo.com/iocs.csv,https://taxii.exemplo.com/stix.json
MINI_SOAR_FEED_URLS=

# [Opcional] Formato dos feeds: csv | stix | auto (padrão: auto)
# auto: detecta automaticamente pelo conteúdo
MINI_SOAR_FEED_FORMAT=auto

# [Opcional] Nome da coluna CSV que contém o valor do IOC (padrão: ioc)
MINI_SOAR_FEED_CSV_IOC_COLUMN=ioc

# [Opcional] Intervalo de polling periódico em minutos (padrão: 60)
MINI_SOAR_FEED_INTERVAL_MINUTES=60

# [Opcional] Timeout HTTP para download dos feeds em segundos (padrão: 30)
MINI_SOAR_FEED_TIMEOUT=30
